{
  "name": "martian-trail",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "GITHUB_PAGES=true vite build",
    "build:native": "CAPACITOR=true vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "e2e": "playwright test",
    "cap:sync": "pnpm build:native && cap sync android",
    "cap:run:android": "cap run android",
    "android:debug": "pnpm cap:sync && cd android && ./gradlew assembleDebug",
    "assets:fetch": "node scripts/fetch-itch-assets.mjs",
    "genai:events": "tsx scripts/genai-events.ts",
    "genai:portraits": "tsx scripts/genai-portraits.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.41.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  }
}
