{
  "name": "martian-trail",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "GITHUB_PAGES=true vite build",
    "build:native": "CAPACITOR=true vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "e2e": "playwright test",
    "cap:sync": "pnpm build:native && cap sync android",
    "cap:run:android": "cap run android",
    "android:debug": "pnpm cap:sync && cd android && ./gradlew assembleDebug",
    "assets:fetch": "node scripts/fetch-itch-assets.mjs",
    "genai:events": "tsx scripts/genai-events.ts",
    "genai:portraits": "tsx scripts/genai-portraits.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.0.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "dotenv": "^17.4.2",
    "pixi.js": "^8.19.0"
  }
}
